const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting) e.target.style.opacity = '1';
  });
}, {threshold:0.1});
document.querySelectorAll('.chart-card, .concl-card, .resumen-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transition = 'opacity 0.6s ease';
  observer.observe(el);
});
</script>
</body>
</html>
